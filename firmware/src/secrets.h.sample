/**
 * ⚠️  Рекомендация для production:
 *   Перенесите эти значения в NVS (Preferences) с начальным provisioning
 *   через captive portal (WiFiManager) или OTA-конфиг, и удалите этот файл
 *   из репозитория (.gitignore: src/secrets.h).
 *
 * ⚠️  Это ШАБЛОН (secrets.h.sample). Он коммитится в репо как референс.
 *     Реальный файл src/secrets.h лежит локально (он в .gitignore).
 *     Скопируйте этот sample в secrets.h и подставьте свои значения:
 *       cp firmware/src/secrets.h.sample firmware/src/secrets.h
 *       $EDITOR firmware/src/secrets.h
 */
#pragma once

// --- Отладочное логирование через Serial ---
// 1 = печатать события (PIR, mode changes, autoff, effects), 0 = тишина (production).
// Можно переопределить через build_flags в platformio.ini:
//   build_flags = ... -DDEBUG_LOG_ENABLED=0
#ifndef DEBUG_LOG_ENABLED
  #define DEBUG_LOG_ENABLED 1
#endif

// --- WiFi ---
const char* WIFI_SSID = "YOUR_WIFI_SSID";
const char* WIFI_PASS = "YOUR_WIFI_PASSWORD";

// --- MQTT ---
const char* MQTT_SERVER = "YOUR_MQTT_HOST";    // например, "192.168.1.10" или "mqtt.local"
const int   MQTT_PORT   = 1883;
const char* MQTT_USER   = "YOUR_MQTT_USER";
const char* MQTT_PASS   = "YOUR_MQTT_PASSWORD";

// --- Базовый префикс топиков (обычно уникален для каждого устройства/комнаты) ---
const char* MQTT_BASE = "home/flat/bath/mirror";

// Префикс Home Assistant MQTT Discovery (по умолчанию "homeassistant",
// меняйте только если в HA перенастроили discovery prefix).
const char* HA_DISCOVERY_PREFIX = "homeassistant";

// --- Команды (формируются как <MQTT_BASE>/<sub>/set) ---
// <MQTT_BASE>/set               — legacy JSON (HA JSON Light): {state, brightness, color}
const char* TOPIC_SET        = "home/flat/bath/mirror/set";
// <MQTT_BASE>/+/set            — wildcard для motion/effect/makeup/motion_disable
const char* TOPIC_BASE_SET   = "home/flat/bath/mirror/+/set";
// <MQTT_BASE>/motion/set       — явное вкл/выкл реакции на PIR ("ON"/"OFF")
const char* TOPIC_MOTION_SET = "home/flat/bath/mirror/motion/set";
// <MQTT_BASE>/makeup/set       — переключение режима Макияж (W-канал, белый свет)
const char* TOPIC_MAKEUP_SET = "home/flat/bath/mirror/makeup/set";
// <MQTT_BASE>/motion_disable/set — отключить реакцию на PIR на время (для Node-RED).
//                                  В HA discovery НЕ публикуется (чтобы не светился). Реактивация — кнопкой (удержание >500 мс).
const char* TOPIC_MOTION_DISABLE_SET  = "home/flat/bath/mirror/motion_disable/set";

// --- Телеметрия (outgoing, retain=true) ---
// <MQTT_BASE>/state            — JSON-статус: state, brightness, brightness_pct, color, color_mode, moveDetection, makeup
const char* TOPIC_STATE        = "home/flat/bath/mirror/state";
// <MQTT_BASE>/motion/state     — "ON"/"OFF" для binary_sensor в HA
const char* TOPIC_MOTION_STATE = "home/flat/bath/mirror/motion/state";
// <MQTT_BASE>/makeup/state     — "ON"/"OFF" для switch в HA
const char* TOPIC_MAKEUP_STATE = "home/flat/bath/mirror/makeup/state";
// <MQTT_BASE>/motion_disable/state — текущее значение pirDisabledByUser.
//                                    В HA НЕ отдаём (discovery не публикует), только MQTT-броадкаст для Node-RED.
//                                    retain=false: после ребута ESP pirDisabledByUser = false по умолчанию,
//                                    состояние не переживает питание/OTA.
const char* TOPIC_MOTION_DISABLE_STATE = "home/flat/bath/mirror/motion_disable/state";
